# Address of your running ComfyUI server.
COMFY_BASE_URL=http://127.0.0.1:8188

# Override the WebSocket URL for live updates from ComfyUI.
# By default the panel uses its own server as a WS proxy on /api/comfy/ws
# (this bypasses ComfyUI's DNS-rebinding origin check).
# Uncomment only if you really need to bypass the proxy:
# NEXT_PUBLIC_COMFY_WS_URL=ws://127.0.0.1:8188/ws
